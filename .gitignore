# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment / secrets — NEVER commit these ────────────────
.env
.env.local
.env.*.local
# Template is safe to commit:
!.env.example

# ── OPTFLOW runtime files ──────────────────────────────────────
.optflow.pid
.optflow_api.pid
.optflow_ui.pid
logs/
logs/**
*.log

# ── user_data/ — personal files, never committed ────────────
user_data/*
!user_data/.gitkeep

# ── Old root-level locations (superseded by user_data/) ─────
positions.json
positions.json.bak

# ── Node / Frontend ────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
node_modules/

# ── OS files ───────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
ehthumbs.db

# ── Editor files ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Test / coverage ────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
-e 
# ── Personal / local scripts ──────────────────────────────────
sync.sh
verify.sh
