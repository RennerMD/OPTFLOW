# OPTFLOW — API Keys Template
# Copy this file to .env and fill in your keys.
# .env is in .gitignore and will never be committed.
#
# ── Tradier (recommended — free real-time options) ─────────────
# Sign up at https://developer.tradier.com
# Free developer account gives real-time quotes + options chains.
TRADIER_TOKEN=
TRADIER_SANDBOX=false

# ── Polygon.io (optional) ──────────────────────────────────────
# Free tier = 15-min delayed. Starter ($29/mo) = real-time REST.
# Options chains require Starter plan minimum.
# https://polygon.io
POLYGON_API_KEY=
